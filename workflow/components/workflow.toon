imports:
  agents[1]{from,use}:
    ./workflow-agents.ts,"ampDeep,codex,amp,gemini,kimi"
  schemas[1]{from,use}:
    ./workflow-schemas.ts,"TicketSchedule,Discover,Progress,Research,Plan,Implement,TestResults,BuildVerify,SpecReview,CodeReview,CodeReviewCodex,CodeReviewGemini,ReviewFix,Report,IntegrationTest,CategoryReview,Land"

name: zevm-slop-factory

agents[5]{name,type,provider,model,instructions,timeoutMs}:
  amp-deep,api,anthropic,amp-deep,"Best orchestrator and deepest thinker. Expensive \u2014 reserve for high-stakes work.",3600000
  codex,codex,,gpt-5.3-codex,"Main workhorse for bulk implementation. Good at Zig code.",3600000
  amp,api,anthropic,amp,"Fast Amp agent for testing and review-fix cycles.",3600000
  gemini,gemini,,gemini-3.1-pro-preview,"Large context window. Best for planning and architecture analysis.",1800000
  kimi,kimi,,,"Cheapest agent. Use for simple work: RPC handler wiring and boilerplate.",3600000

input:
  maxConcurrency: number
  taskRetries: number

schemas:
  TicketScheduleJob:
    jobId: string
    jobType: string
    agentId: string
    fallbackAgentIds: "string[]"
    ticketId: string?
    focusId: string?
    reason: string
  TicketSchedule:
    jobs: "TicketScheduleJob[]"
    reasoning: string
  Discover:
    tickets: "DiscoverTicket[]"
    reasoning: string
    completionEstimate: string
  Progress:
    progressFilePath: string?
    summary: string
    ticketsCompleted: "string[]?"
    ticketsRemaining: "string[]?"
  Research:
    contextFilePath: string
    summary: string
  Plan:
    planFilePath: string
    implementationSteps: "string[]?"
  Implement:
    whatWasDone: string
    filesCreated: "string[]?"
    filesModified: "string[]?"
    nextSteps: string?
  TestResults:
    goTestsPassed: boolean
    rustTestsPassed: boolean
    e2eTestsPassed: boolean
    sqlcGenPassed: boolean
    failingSummary: string?
  SpecReview:
    severity: "none" | "minor" | "major" | "critical"
    feedback: string
    issues: "string[]?"
  CodeReview:
    severity: "none" | "minor" | "major" | "critical"
    feedback: string
    issues: "string[]?"
  ReviewFix:
    allIssuesResolved: boolean
    summary: string
  Report:
    ticketId: string
    status: "partial" | "complete" | "blocked"
    summary: string
    filesChanged: "string[]?"
    testsAdded: "string[]?"
    reviewRounds: number
    struggles: "string[]?"
    lessonsLearned: "string[]?"
  Land:
    merged: boolean
    mergeCommit: string?
    ciPassed: boolean
    summary: string
    evicted: boolean
    evictionReason: string?
    evictionDetails: string?

components:
  TicketPipeline:
    params:
      ticketId: string
      ticketTitle: string
      ticketDescription: string
      ticketCategory: string
    steps[8]:
      - id: "{id}-research"
        agent: amp-deep
        output: Research
        timeout: 30m
        maxAttempts: 3
        prompt: "Research ticket {params.ticketId}: {params.ticketTitle}\n\nDescription: {params.ticketDescription}\nCategory: {params.ticketCategory}\n\nCRITICAL \u2014 check voltaire and guillotine-mini FIRST:\n1. voltaire (../voltaire/packages/voltaire-zig/src/) \u2014 JSON-RPC types, StateManager, ForkBackend, Blockchain, EVM, crypto, precompiles, primitives\n2. guillotine-mini (../bench/guillotine-mini/) \u2014 EVM interpreter, RPC dispatch/routing, envelope parsing, response serialization\n3. If they're MISSING something, add it THERE, not in zevm\n\nWrite research context to docs/context/{params.ticketId}.md"
      - id: "{id}-plan"
        agent: gemini
        output: Plan
        timeout: 20m
        maxAttempts: 3
        prompt: "Create implementation plan for ticket {params.ticketId}: {params.ticketTitle}\n\nResearch summary: {{id}-research.summary}\nContext file: {{id}-research.contextFilePath}\n\nWrite TDD plan: tests FIRST, then implementation.\nWrite plan to docs/plans/{params.ticketId}.md\n\nZIG STYLE: No local type aliases. No stored allocators. Fully qualified paths only."
      - id: "{id}-implement"
        agent: codex
        output: Implement
        timeout: 60m
        maxAttempts: 3
        prompt: "Implement ticket {params.ticketId}: {params.ticketTitle}\n\nPlan: {{id}-plan.planFilePath}\nSteps: {{id}-plan.implementationSteps}\n\nFollow the plan exactly. Write tests first, then implementation.\nRun zig build test to verify. Run zig fmt src/ to format.\n\nZIG STYLE: No local type aliases. No stored allocators. Fully qualified paths only.\nDO NOT reinvent voltaire or guillotine-mini functionality."
      - id: "{id}-test"
        agent: amp
        output: TestResults
        timeout: 30m
        maxAttempts: 3
        prompt: "Run all tests for ticket {params.ticketId}: {params.ticketTitle}\n\nImplementation: {{id}-implement.whatWasDone}\n\nCommands: zig build test\n\nFix any failing tests. Commit fixes with fix prefix."
      - kind: parallel
        children[2]:
          - id: "{id}-spec-review"
            agent: gemini
            output: SpecReview
            timeout: 20m
            maxAttempts: 3
            prompt: "Review implementation of {params.ticketId} against specs.\n\nFiles created: {{id}-implement.filesCreated}\nFiles modified: {{id}-implement.filesModified}\nTests: {{id}-test.goTestsPassed ? 'PASS' : 'FAIL'}\n\nCheck against:\n1. Zig style: no local type aliases, no stored allocators, fully qualified paths\n2. Architecture: zevm is thin integration layer, heavy logic in voltaire/guillotine-mini\n3. Test coverage: every RPC handler has a unit test"
          - id: "{id}-code-review"
            agent: amp-deep
            output: CodeReview
            timeout: 20m
            maxAttempts: 3
            prompt: "Code review for ticket {params.ticketId}: {params.ticketTitle}\n\nFiles created: {{id}-implement.filesCreated}\nFiles modified: {{id}-implement.filesModified}\n\nReview checklist:\n1. DO NOT REINVENT \u2014 check voltaire and guillotine-mini first\n2. UPSTREAM FIRST \u2014 add missing features to voltaire/guillotine-mini, not zevm\n3. Zig style \u2014 no local type aliases, no stored allocators\n4. Security \u2014 no command injection, proper input validation"
      - kind: loop
        id: "{id}-review-loop"
        maxIterations: 3
        until: "{{id}-review-fix.allIssuesResolved} == true"
        onMaxReached: return-last
        children[1]:
          - id: "{id}-review-fix"
            agent: codex
            output: ReviewFix
            timeout: 30m
            maxAttempts: 3
            prompt: "Fix review issues for ticket {params.ticketId}.\n\nSpec review ({{{id}-spec-review.severity}}): {{id}-spec-review.feedback}\nSpec issues: {{id}-spec-review.issues}\n\nCode review ({{{id}-code-review.severity}}): {{id}-code-review.feedback}\nCode issues: {{id}-code-review.issues}\n\nFix all issues. Run zig build test to verify. Run zig fmt src/."
      - id: "{id}-report"
        agent: amp
        output: Report
        timeout: 15m
        maxAttempts: 3
        prompt: "Generate completion report for ticket {params.ticketId}: {params.ticketTitle}\n\nReviews resolved: {{id}-review-fix.allIssuesResolved}\nSummary: {{id}-review-fix.summary}\nImplementation: {{id}-implement.whatWasDone}\nFiles: {{id}-implement.filesCreated}, {{id}-implement.filesModified}"

steps[1]:
  - kind: loop
    id: main-loop
    maxIterations: 999
    until: "false"
    onMaxReached: return-last
    children[3]:
      - id: ticket-scheduler
        agent: amp
        output: TicketSchedule
        timeout: 10m
        maxAttempts: 2
        prompt: "You are the ticket scheduler for ZEVM \u2014 Zig Ethereum Virtual Machine.\n\nSchedule the next batch of jobs. Consider pipeline stages, dependencies, and agent strengths.\nMax concurrency: {input.maxConcurrency}. Task retries: {input.taskRetries}.\n\nAvailable agents:\namp-deep: Best orchestrator and deepest thinker. Expensive.\ncodex: Main workhorse for bulk implementation. Good at Zig code.\namp: Fast Amp agent for testing, review-fix cycles, and lighter research.\ngemini: Large context window. Best for planning and architecture analysis.\nkimi: Cheapest agent. Use for simple work: RPC handler wiring, boilerplate.\n\nAvailable focuses (implementation):\ncat-1-rpc-server, cat-2-eth-read, cat-3-eth-call, cat-4-eth-send, cat-5-block-queries, cat-6-mining, cat-7-snapshots, cat-8-state-manip, cat-9-impersonation, cat-10-forking, cat-11-tracing, cat-12-filters, cat-13-time\n\nAvailable focuses (test suites):\ntest-rlp, test-trie, test-transaction, test-blockchain, test-difficulty, test-abi, test-eof, test-state-frontier, test-state-berlin, test-state-cancun, test-hive-rpc\n\nJob types: discovery, progress-update, codebase-review, integration-test, ticket:research, ticket:plan, ticket:implement, ticket:test, ticket:build-verify, ticket:spec-review, ticket:code-review, ticket:review-fix, ticket:report"
      - kind: parallel
        maxConcurrency: 4
        children[2]:
          - id: discover
            agent: amp-deep
            output: Discover
            timeout: 30m
            maxAttempts: 3
            prompt: "Discover implementation tickets for ZEVM.\n\nCheck voltaire (../voltaire/packages/voltaire-zig/src/) and guillotine-mini (../bench/guillotine-mini/) FIRST.\nCheck what's already done in zevm before creating tickets.\n\nExplore specs at docs/specs/ for reference.\nReference: edr/crates/edr_provider/src/requests/, foundry/, ../tevm-monorepo/packages/actions/src/"
          - id: progress-update
            agent: kimi
            output: Progress
            timeout: 15m
            maxAttempts: 3
            prompt: "Update PROGRESS.md for ZEVM \u2014 Zig Ethereum Virtual Machine.\nSummarize completed tickets, remaining work, and current status."
      - kind: parallel
        maxConcurrency: 4
        children[1]:
          - id: ticket-1
            kind: component
            use: TicketPipeline
            with:
              ticketId: "{ticket-scheduler.jobs[0].ticketId}"
              ticketTitle: Scheduled ticket
              ticketDescription: Implementation ticket from scheduler
              ticketCategory: implementation