imports:
  agents[5]:
    - from: ./workflow-agents.ts
      use[5]: ampDeep,codex,amp,gemini,kimi
  schemas[17]:
    - from: ./workflow-schemas.ts
      use[17]: TicketSchedule,Discover,Progress,Research,Plan,Implement,TestResults,BuildVerify,SpecReview,CodeReview,CodeReviewCodex,CodeReviewGemini,ReviewFix,Report,IntegrationTest,CategoryReview,Land

name: zevm-slop-factory

agents:
  amp-deep:
    type: api
    provider: anthropic
    model: amp-deep
    instructions: "Best orchestrator and deepest thinker. Use for the most important research tasks that require careful reasoning about how to integrate voltaire/guillotine-mini. Expensive — reserve for high-stakes work."
    timeoutMs: 3600000
  codex:
    type: codex
    model: gpt-5.3-codex
    instructions: "Main workhorse for bulk implementation. Good at following instructions and writing Zig code. Use for most implementation tickets."
    timeoutMs: 3600000
  amp:
    type: api
    provider: anthropic
    model: amp
    instructions: "Fast Amp agent for testing, review-fix cycles, and lighter research. Good balance of speed and quality."
    timeoutMs: 3600000
  gemini:
    type: gemini
    model: gemini-3.1-pro-preview
    instructions: "Very smart with large context window. Best for planning, reading reference implementations (edr, tevm-monorepo), and architecture analysis. Unreliable at tool calls."
    timeoutMs: 1800000
  kimi:
    type: kimi
    instructions: "Cheapest agent. Use as much as possible for simple work: straightforward RPC handler wiring, boilerplate, and low-complexity tickets."
    timeoutMs: 3600000

input:
  maxConcurrency: number
  taskRetries: number

schemas:
  TicketScheduleJob:
    jobId: string
    jobType: string
    agentId: string
    fallbackAgentIds: "string[]"
    ticketId: string?
    focusId: string?
    reason: string

  TicketSchedule:
    jobs: "TicketScheduleJob[]"
    reasoning: string

  Discover:
    tickets: "DiscoverTicket[]"
    reasoning: string
    completionEstimate: string

  Progress:
    progressFilePath: string?
    summary: string
    ticketsCompleted: "string[]?"
    ticketsRemaining: "string[]?"

  Research:
    contextFilePath: string
    summary: string

  Plan:
    planFilePath: string
    implementationSteps: "string[]?"

  Implement:
    whatWasDone: string
    filesCreated: "string[]?"
    filesModified: "string[]?"
    nextSteps: string?

  TestResults:
    goTestsPassed: boolean
    rustTestsPassed: boolean
    e2eTestsPassed: boolean
    sqlcGenPassed: boolean
    failingSummary: string?

  SpecReview:
    severity: "none" | "minor" | "major" | "critical"
    feedback: string
    issues: "string[]?"

  CodeReview:
    severity: "none" | "minor" | "major" | "critical"
    feedback: string
    issues: "string[]?"

  ReviewFix:
    allIssuesResolved: boolean
    summary: string

  Report:
    ticketId: string
    status: "partial" | "complete" | "blocked"
    summary: string
    filesChanged: "string[]?"
    testsAdded: "string[]?"
    reviewRounds: number
    struggles: "string[]?"
    lessonsLearned: "string[]?"

  Land:
    merged: boolean
    mergeCommit: string?
    ciPassed: boolean
    summary: string
    evicted: boolean
    evictionReason: string?
    evictionDetails: string?

components:
  TicketPipeline:
    params:
      ticketId: string
      ticketTitle: string
      ticketDescription: string
      ticketCategory: string
    steps[8]:
      - id: "{id}-research"
        agent: amp-deep
        output: Research
        timeout: 30m
        retry:
          maxAttempts: 3
        prompt: |
          Research ticket {params.ticketId}: {params.ticketTitle}

          Description: {params.ticketDescription}
          Category: {params.ticketCategory}

          CRITICAL — check voltaire and guillotine-mini FIRST:
          1. voltaire (../voltaire/packages/voltaire-zig/src/) — JSON-RPC types, StateManager, ForkBackend, Blockchain, EVM, crypto, precompiles, primitives
          2. guillotine-mini (../bench/guillotine-mini/) — EVM interpreter, RPC dispatch/routing, envelope parsing, response serialization
          3. If they're MISSING something, add it THERE, not in zevm

          Write research context to docs/context/{params.ticketId}.md

      - id: "{id}-plan"
        agent: gemini
        output: Plan
        timeout: 20m
        retry:
          maxAttempts: 3
        prompt: |
          Create implementation plan for ticket {params.ticketId}: {params.ticketTitle}

          Research summary: {{id}-research.summary}
          Context file: {{id}-research.contextFilePath}

          Write TDD plan: tests FIRST, then implementation.
          Write plan to docs/plans/{params.ticketId}.md

          ZIG STYLE: No local type aliases. No stored allocators. Fully qualified paths only.

      - id: "{id}-implement"
        agent: codex
        output: Implement
        timeout: 60m
        retry:
          maxAttempts: 3
        prompt: |
          Implement ticket {params.ticketId}: {params.ticketTitle}

          Plan: {{id}-plan.planFilePath}
          Steps: {{id}-plan.implementationSteps}

          Follow the plan exactly. Write tests first, then implementation.
          Run `zig build test` to verify. Run `zig fmt src/` to format.

          ZIG STYLE: No local type aliases. No stored allocators. Fully qualified paths only.
          DO NOT reinvent voltaire or guillotine-mini functionality.

      - id: "{id}-test"
        agent: amp
        output: TestResults
        timeout: 30m
        retry:
          maxAttempts: 3
        prompt: |
          Run all tests for ticket {params.ticketId}: {params.ticketTitle}

          Implementation: {{id}-implement.whatWasDone}

          Commands:
          - zig build test

          Fix any failing tests. Commit fixes with 🐛 fix prefix.

      - kind: parallel
        children[2]:
          - id: "{id}-spec-review"
            agent: gemini
            output: SpecReview
            timeout: 20m
            retry:
              maxAttempts: 3
            prompt: |
              Review implementation of {params.ticketId} against specs.

              Files created: {{id}-implement.filesCreated}
              Files modified: {{id}-implement.filesModified}
              Tests: {{id}-test.goTestsPassed ? "PASS" : "FAIL"}

              Check against:
              - Zig style: no local type aliases, no stored allocators, fully qualified paths
              - Architecture: zevm is thin integration layer, heavy logic in voltaire/guillotine-mini
              - Test coverage: every RPC handler has a unit test

          - id: "{id}-code-review"
            agent: amp-deep
            output: CodeReview
            timeout: 20m
            retry:
              maxAttempts: 3
            prompt: |
              Code review for ticket {params.ticketId}: {params.ticketTitle}

              Files created: {{id}-implement.filesCreated}
              Files modified: {{id}-implement.filesModified}

              Review checklist:
              - DO NOT REINVENT — check voltaire and guillotine-mini first
              - UPSTREAM FIRST — add missing features to voltaire/guillotine-mini, not zevm
              - Zig style — no local type aliases, no stored allocators
              - Security — no command injection, proper input validation

      - kind: loop
        id: "{id}-review-loop"
        maxIterations: 3
        until: "{{id}-review-fix.allIssuesResolved} == true"
        onMaxReached: return-last
        children[1]:
          - id: "{id}-review-fix"
            agent: codex
            output: ReviewFix
            timeout: 30m
            retry:
              maxAttempts: 3
            prompt: |
              Fix review issues for ticket {params.ticketId}.

              Spec review ({{{id}-spec-review.severity}}): {{id}-spec-review.feedback}
              Spec issues: {{id}-spec-review.issues}

              Code review ({{{id}-code-review.severity}}): {{id}-code-review.feedback}
              Code issues: {{id}-code-review.issues}

              Fix all issues. Run `zig build test` to verify. Run `zig fmt src/`.

      - id: "{id}-report"
        agent: amp
        output: Report
        timeout: 15m
        retry:
          maxAttempts: 3
        prompt: |
          Generate completion report for ticket {params.ticketId}: {params.ticketTitle}

          Reviews resolved: {{id}-review-fix.allIssuesResolved}
          Summary: {{id}-review-fix.summary}
          Implementation: {{id}-implement.whatWasDone}
          Files: {{id}-implement.filesCreated}, {{id}-implement.filesModified}

steps[1]:
  - kind: loop
    id: main-loop
    maxIterations: 999
    until: "false"
    onMaxReached: return-last
    children[3]:
      - id: ticket-scheduler
        agent: amp
        output: TicketSchedule
        timeout: 10m
        retry:
          maxAttempts: 2
        prompt: |
          You are the ticket scheduler for ZEVM — Zig Ethereum Virtual Machine.

          Schedule the next batch of jobs. Consider pipeline stages, dependencies, and agent strengths.
          Max concurrency: {input.maxConcurrency}. Task retries: {input.taskRetries}.

          Available agents:
          | Agent ID | Description |
          |----------|-------------|
          | amp-deep | Best orchestrator and deepest thinker. Expensive — reserve for high-stakes work. |
          | codex | Main workhorse for bulk implementation. Good at Zig code. |
          | amp | Fast Amp agent for testing, review-fix cycles, and lighter research. |
          | gemini | Large context window. Best for planning and architecture analysis. |
          | kimi | Cheapest agent. Use for simple work: RPC handler wiring, boilerplate. |

          Available focuses (implementation):
          - cat-1-rpc-server: HTTP JSON-RPC Server
          - cat-2-eth-read: Read-only eth_* Methods
          - cat-3-eth-call: eth_call + eth_estimateGas
          - cat-4-eth-send: eth_sendTransaction + Transaction Pool
          - cat-5-block-queries: Block Query Methods
          - cat-6-mining: Mining Modes
          - cat-7-snapshots: Snapshot & Revert
          - cat-8-state-manip: State Manipulation
          - cat-9-impersonation: Account Impersonation
          - cat-10-forking: Fork Mode
          - cat-11-tracing: Debug & Tracing
          - cat-12-filters: Filters & Subscriptions
          - cat-13-time: Time Manipulation

          Available focuses (test suites):
          - test-rlp, test-trie, test-transaction, test-blockchain
          - test-difficulty, test-abi, test-eof
          - test-state-frontier, test-state-berlin, test-state-cancun
          - test-hive-rpc

          Job types: discovery, progress-update, codebase-review, integration-test,
          ticket:research, ticket:plan, ticket:implement, ticket:test,
          ticket:build-verify, ticket:spec-review, ticket:code-review,
          ticket:review-fix, ticket:report

      - kind: parallel
        maxConcurrency: 4
        children[2]:
          - id: discover
            agent: amp-deep
            output: Discover
            timeout: 30m
            retry:
              maxAttempts: 3
            prompt: |
              Discover implementation tickets for ZEVM.

              Check voltaire (../voltaire/packages/voltaire-zig/src/) and guillotine-mini (../bench/guillotine-mini/) FIRST.
              Check what's already done in zevm before creating tickets.

              Explore specs at docs/specs/ for reference.
              Reference: edr/crates/edr_provider/src/requests/, foundry/, ../tevm-monorepo/packages/actions/src/

          - id: progress-update
            agent: kimi
            output: Progress
            timeout: 15m
            retry:
              maxAttempts: 3
            prompt: |
              Update PROGRESS.md for ZEVM — Zig Ethereum Virtual Machine.
              Summarize completed tickets, remaining work, and current status.

      - kind: parallel
        maxConcurrency: 4
        children[1]:
          - id: ticket-1
            kind: component
            use: TicketPipeline
            with:
              ticketId: "{ticket-scheduler.jobs[0].ticketId}"
              ticketTitle: "Scheduled ticket"
              ticketDescription: "Implementation ticket from scheduler"
              ticketCategory: "implementation"
